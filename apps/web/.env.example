# Logo.dev API Token (optional, for fetching company logos)
# Get your free token at https://logo.dev
VITE_LOGO_DEV_TOKEN=your_publishable_token_here

# API Configuration
VITE_API_URL=http://localhost:3001

# PostHog Analytics (optional)
# Get your project API key from https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=your_posthog_project_api_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com
